---
/**
 * Hero override — suppresses the Starlight hero on blog and changelog pages,
 * since we use hero: {} only as a layout signal to collapse the two-panel structure.
 */
import DefaultHero from 'node_modules/@astrojs/starlight/components/Hero.astro'

const path = Astro.url.pathname
const suppressHero = path.includes('/blog/') || path.includes('/changelog/')
---

{!suppressHero && <DefaultHero />}
