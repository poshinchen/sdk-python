---
import type { AreaCount } from '../../util/changelog'

interface Props { areas: AreaCount[] }
const { areas } = Astro.props
---
<div class="cl-scrim" data-cl-scrim></div>
<form class="cl-rail" role="search" aria-label="Filter changelog" data-cl-rail onsubmit="return false">
  <input class="cl-search" type="search" placeholder="Search titles, authors…" data-cl-search aria-label="Search changelog" />
  <p class="cl-rail-label" id="cl-area-label">Area</p>
  <ul class="cl-areas" aria-labelledby="cl-area-label">
    {areas.map(({ area, count }) => (
      <li class="cl-area-item">
        <button class="cl-area" type="button" data-cl-area={area} aria-pressed="false">
          {area}<span class="cl-count">{count}</span>
        </button>
      </li>
    ))}
  </ul>
</form>
