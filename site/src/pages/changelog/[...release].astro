---
import type { GetStaticPaths } from 'astro'
import ChangelogLayout from '../../layouts/ChangelogLayout.astro'
import ChangelogVersion from '../../components/changelog/ChangelogVersion.astro'
import { getReleasePaths, formatChangelogDate, releaseSlug } from '../../util/changelog'
import { pathWithBase } from '../../util/links'
import { streamLabel } from '../../config/changelog'
import '../../styles/changelog.css'

export const getStaticPaths: GetStaticPaths = async () => {
  return getReleasePaths()
}

// release + same-stream neighbors are precomputed in getReleasePaths (no
// per-page re-read of the whole collection).
const { release, newer, older } = Astro.props
const d = release.data

const label = streamLabel(d.sdk, d.language)
const title = `${label} v${d.version}`
const description = `Release notes for ${label} v${d.version}, published ${formatChangelogDate(d.date)}.`

const linkFor = (r: typeof release) => pathWithBase(`/changelog/${releaseSlug(r)}/`)
---
<ChangelogLayout title={title} description={description}>
  <div class="cl-page cl-detail">
    <a class="cl-back" href={pathWithBase('/changelog/')}><span aria-hidden="true">←</span> All releases</a>
    <ol class="cl-feed-list" role="list">
      <li class="cl-version-item"><ChangelogVersion release={release} detail /></li>
    </ol>
    <nav class="cl-pager" aria-label={`Other ${label} releases`}>
      {older ? (
        <a class="cl-pager-link cl-pager-prev" href={linkFor(older)} rel="prev">
          <span class="cl-pager-dir"><span aria-hidden="true">←</span> Older</span>
          <span class="cl-pager-ver">v{older.data.version}</span>
        </a>
      ) : <span />}
      {newer ? (
        <a class="cl-pager-link cl-pager-next" href={linkFor(newer)} rel="next">
          <span class="cl-pager-dir">Newer <span aria-hidden="true">→</span></span>
          <span class="cl-pager-ver">v{newer.data.version}</span>
        </a>
      ) : <span />}
    </nav>
  </div>
</ChangelogLayout>
